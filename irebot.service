; sudo nano /etc/systemd/system/irebot.service
; sudo systemctl daemon-reload
; sudo systemctl enable irebot
; sudo systemctl start irebot
; sudo journalctl -u irebot -e

[Unit]
Description=irebot
After=network-online.target

[Service]
Type=simple
WorkingDirectory=/home/ubuntu/IreBot/
ExecStart=uv run src/main.py
User=ubuntu
Restart=always
RestartSec=10

[Install]
WantedBy=multi-user.target